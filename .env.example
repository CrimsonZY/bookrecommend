# Frontend: API base (no trailing slash)
# Option A (recommended for this static frontend):
#   Set a global variable before scripts/main.js loads:
#   <script>window.BOOKRECOMMEND_API_BASE="https://your-backend.example.com";</script>
BOOKRECOMMEND_API_BASE=http://127.0.0.1:8001

# Backend: CORS allowlist (comma-separated)
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Backend: deployment port (usually provided by platform)
PORT=8001
